# ===========================================================
# Zentyzone — Plantilla de variables de entorno
# -----------------------------------------------------------
# Este archivo SÍ se sube a GitHub. NO escribas claves reales aquí.
# Para usar el proyecto: copia este archivo como ".env.local"
# y rellena los valores reales en ESE archivo.
# ===========================================================

# --- Supabase (autenticación + base de datos) ---
# Las variables que empiezan con VITE_ son visibles en el navegador.
# La URL y la "anon key" están diseñadas para ser públicas, no hay problema.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Anthropic Claude API (el agente Zenty) ---
# ¡SECRETA! NO lleva el prefijo VITE_ a propósito: así NUNCA llega
# al navegador. Solo la usa la función serverless en el servidor.
ANTHROPIC_API_KEY=
